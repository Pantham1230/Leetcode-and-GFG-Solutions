class Solution(object):
    def continuousSubarrays(self, nums):
        """
        :type nums: List[int]
        :rtype: int
        """
        min_d = deque()
        max_d = deque()
        left = 0
        ans = 0
        for right in range(len(nums)):
            while min_d and nums[min_d[-1]] > nums[right]:
                min_d.pop()
            min_d.append(right)
            while max_d and nums[max_d[-1]] < nums[right]:
                max_d.pop()
            max_d.append(right)
            while nums[max_d[0]] - nums[min_d[0]] > 2:
                left += 1
                if min_d[0] < left:
                    min_d.popleft()
                if max_d[0] < left:
                    max_d.popleft()
            ans += (right - left + 1)
        return ans
