import math
class Solution:
    def print_divisors(self, n):
        # code here
        divisors = []
        for i in range(1, int(math.sqrt(n)) + 1):
            if n % i == 0:
                divisors.append(i)
                if i != n // i:
                    divisors.append(n // i)
        for d in sorted(divisors):
            print(d, end=" ")
